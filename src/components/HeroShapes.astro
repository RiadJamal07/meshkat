---
import diamondSvg from '~/assets/brand/shapes/Meshkat-Shapes-Diamond.svg?raw';
import circleSvg from '~/assets/brand/shapes/Meshkat-Shapes-Circle.svg?raw';
import square2Svg from '~/assets/brand/shapes/Meshkat-Shapes-square2.svg?raw';
import squareSvg from '~/assets/brand/shapes/Meshkat-Shapes-Square.svg?raw';
import dotsSvg from '~/assets/brand/shapes/Meshkat-Shapes-Dots.svg?raw';

interface ShapeDef {
  id: string;
  svg: string;
  x: number;
  y: number;
  size: 'small' | 'medium';
  opacity: number;
  mobile: boolean;
  scrollRate: number;
}

const shapes: ShapeDef[] = [
  { id: 'diamond', svg: diamondSvg, x: 8,  y: 18, size: 'medium', opacity: 0.72, mobile: true,  scrollRate: 0.18 },
  { id: 'circle',  svg: circleSvg,  x: 82, y: 12, size: 'small',  opacity: 0.70, mobile: false, scrollRate: 0.22 },
  { id: 'square2', svg: square2Svg, x: 88, y: 55, size: 'small',  opacity: 0.68, mobile: false, scrollRate: 0.32 },
  { id: 'square',  svg: squareSvg,  x: 6,  y: 68, size: 'medium', opacity: 0.72, mobile: true,  scrollRate: 0.34 },
  { id: 'dots',    svg: dotsSvg,    x: 62, y: 90, size: 'small',  opacity: 0.70, mobile: true,  scrollRate: 0.42 },
];
---

<div class="hero-shapes" data-hero-shapes aria-hidden="true">
  {shapes.map((shape) => (
    <div
      class:list={[
        'hero-shape',
        `hero-shape--${shape.size}`,
        !shape.mobile && 'hero-shape--desktop-only',
      ]}
      data-hero-shape
      data-shape-id={shape.id}
      data-scroll-rate={shape.scrollRate}
      style={`--anchor-x: ${shape.x}%; --anchor-y: ${shape.y}%; --shape-opacity: ${shape.opacity};`}
      set:html={shape.svg}
    />
  ))}
</div>

<style>
  .hero-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .hero-shape {
    position: absolute;
    left: var(--anchor-x);
    top: var(--anchor-y);
    opacity: var(--shape-opacity);
    will-change: transform;
    transform: translate3d(-50%, -50%, 0);
    backface-visibility: hidden;
  }

  .hero-shape svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-shape svg * {
    transition: fill 400ms ease;
  }

  .hero-shapes[data-color-mode='mono'] .hero-shape svg * {
    fill: var(--color-brick);
  }

  .hero-shape--small {
    width: clamp(3rem, 5vw, 5rem);
  }

  .hero-shape--medium {
    width: clamp(4rem, 7vw, 6.5rem);
  }

  @media (max-width: 640px) {
    .hero-shape--desktop-only {
      display: none;
    }
    .hero-shape--small,
    .hero-shape--medium {
      width: clamp(2.5rem, 10vw, 4rem);
    }
  }

  :global(.hero-shapes-lines) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-shape {
      will-change: auto;
    }
    .hero-shape svg * {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { variants, type VariantId, type Cursor } from '~/lib/hero-shapes';

  type ColorMode = 'color' | 'mono';

  const STORAGE_KEY = 'meshkat-shapes-variant';
  const COLOR_STORAGE_KEY = 'meshkat-shapes-color';
  const VALID: ReadonlyArray<VariantId> = ['A', 'B', 'C'];
  const VALID_COLORS: ReadonlyArray<ColorMode> = ['color', 'mono'];

  const container = document.querySelector<HTMLElement>('[data-hero-shapes]');
  if (container) {
    const shapes = Array.from(
      container.querySelectorAll<HTMLElement>('[data-hero-shape]'),
    );

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

    gsap.set(shapes, { xPercent: -50, yPercent: -50 });

    const cursor: Cursor = {
      x: -9999,
      y: -9999,
      active: false,
      scrollOffset: window.scrollY,
    };

    const onMove = (e: MouseEvent) => {
      cursor.x = e.clientX;
      cursor.y = e.clientY;
      cursor.active = true;
    };
    const onLeave = () => {
      cursor.active = false;
    };
    const onScroll = () => {
      cursor.scrollOffset = window.scrollY;
    };

    const readStoredVariant = (): VariantId => {
      const url = new URL(window.location.href);
      const param = url.searchParams.get('shapes');
      if (param && VALID.includes(param as VariantId)) return param as VariantId;
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored && VALID.includes(stored as VariantId)) return stored as VariantId;
      } catch (_) {}
      return 'A';
    };

    const readStoredColor = (): ColorMode => {
      const url = new URL(window.location.href);
      const param = url.searchParams.get('shapes-color');
      if (param && VALID_COLORS.includes(param as ColorMode)) return param as ColorMode;
      try {
        const stored = localStorage.getItem(COLOR_STORAGE_KEY);
        if (stored && VALID_COLORS.includes(stored as ColorMode)) return stored as ColorMode;
      } catch (_) {}
      return 'color';
    };

    container.dataset.colorMode = readStoredColor();

    let cleanup: (() => void) | null = null;

    const apply = (id: VariantId) => {
      if (cleanup) {
        cleanup();
        cleanup = null;
      }
      gsap.killTweensOf(shapes);
      gsap.set(shapes, { x: 0, y: 0 });

      if (reduce || coarse) return;

      const fn = variants[id];
      const visible = shapes.filter(
        (shape) => getComputedStyle(shape).display !== 'none',
      );
      cleanup = fn(visible, () => cursor, container);
    };

    if (!reduce && !coarse) {
      window.addEventListener('mousemove', onMove, { passive: true });
      window.addEventListener('mouseleave', onLeave, { passive: true });
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    apply(readStoredVariant());

    window.addEventListener('shapes-variant-change', (e) => {
      const detail = (e as CustomEvent<VariantId>).detail;
      if (VALID.includes(detail)) apply(detail);
    });

    window.addEventListener('shapes-color-change', (e) => {
      const detail = (e as CustomEvent<ColorMode>).detail;
      if (VALID_COLORS.includes(detail)) container.dataset.colorMode = detail;
    });
  }
</script>
