---
const modes = [
  { id: 'color', label: 'Color', aria: 'Shape palette: multicolor brand' },
  { id: 'mono', label: 'Mono', aria: 'Shape palette: single brick tone' },
] as const;
---

<div
  class="hero-shapes-color-picker"
  data-hero-shapes-color-picker
  role="group"
  aria-label="Hero shape color mode"
>
  {modes.map((mode) => (
    <button
      type="button"
      class="hero-shapes-color-pill"
      data-color-mode={mode.id}
      aria-label={mode.aria}
      aria-pressed="false"
    >
      {mode.label}
    </button>
  ))}
</div>

<style>
  .hero-shapes-color-picker {
    display: inline-flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.3rem;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-cream) 40%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-ink) 10%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .hero-shapes-color-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding: 0 0.85rem;
    border: 1px solid color-mix(in oklab, var(--color-ink) 22%, transparent);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-ink-soft);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      color 220ms ease;
  }

  .hero-shapes-color-pill:hover,
  .hero-shapes-color-pill:focus-visible {
    border-color: var(--color-brick);
    color: var(--color-brick);
  }

  .hero-shapes-color-pill[aria-pressed='true'] {
    background: var(--color-brick);
    border-color: var(--color-brick);
    color: var(--color-surface);
  }

  .hero-shapes-color-pill:active {
    border-color: var(--color-brick);
    color: var(--color-brick);
  }

  .hero-shapes-color-pill[aria-pressed='true']:active {
    color: var(--color-surface);
  }

  @media (hover: none) and (pointer: coarse) {
    .hero-shapes-color-pill {
      min-height: 44px;
      padding-inline: 1.1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-shapes-color-pill {
      transition: none;
    }
  }
</style>

<script>
  type ColorMode = 'color' | 'mono';
  const STORAGE_KEY = 'meshkat-shapes-color';
  const VALID: ReadonlyArray<ColorMode> = ['color', 'mono'];

  const picker = document.querySelector<HTMLElement>('[data-hero-shapes-color-picker]');
  if (picker) {
    const pills = Array.from(
      picker.querySelectorAll<HTMLButtonElement>('[data-color-mode]'),
    );

    const readInitial = (): ColorMode => {
      const url = new URL(window.location.href);
      const param = url.searchParams.get('shapes-color');
      if (param && VALID.includes(param as ColorMode)) return param as ColorMode;
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored && VALID.includes(stored as ColorMode)) return stored as ColorMode;
      } catch (_) {}
      return 'color';
    };

    const setActive = (id: ColorMode) => {
      pills.forEach((pill) => {
        pill.setAttribute(
          'aria-pressed',
          pill.dataset.colorMode === id ? 'true' : 'false',
        );
      });
    };

    setActive(readInitial());

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const id = pill.dataset.colorMode as ColorMode | undefined;
        if (!id || !VALID.includes(id)) return;
        setActive(id);
        try {
          localStorage.setItem(STORAGE_KEY, id);
        } catch (_) {}
        window.dispatchEvent(
          new CustomEvent<ColorMode>('shapes-color-change', { detail: id }),
        );
      });
    });
  }
</script>
