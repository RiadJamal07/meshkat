---
import '~/styles/global.css';
import SmoothScroll from '~/components/SmoothScroll.astro';
import CursorGlow from '~/components/CursorGlow.astro';
import FilmGrain from '~/components/FilmGrain.astro';
import ScrollLightRail from '~/components/ScrollLightRail.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'ar';
}

const { title, description, lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0f0d0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5f1ea" media="(prefers-color-scheme: light)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href={Astro.url.href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — link preview card`} />
    <meta property="og:site_name" content="Meshkat Studio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ar_LB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Anti-FOUC: apply persisted theme before first paint. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('meshkat-theme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.setAttribute('data-theme', stored);
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    <slot />
    <ScrollLightRail />
    <CursorGlow />
    <FilmGrain />
    <SmoothScroll />
  </body>
</html>
